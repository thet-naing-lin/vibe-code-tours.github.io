---
import {
  t,
  getLocale,
  localizedPath,
  altLocaleHref,
  type Locale,
} from "../i18n/utils";

const locale: Locale = getLocale(Astro.url.pathname);
const s = t(locale);
const altHref = altLocaleHref(Astro.url.pathname);
const altLabel = s.meta.altLangLabel;

const nav = [
  { href: "/curriculum", label: s.nav.curriculum },
  { href: "/about", label: s.nav.about },
  { href: "/team", label: s.nav.team },
  { href: "/faq", label: s.nav.faq },
  { href: "/sponsors", label: s.nav.sponsors },
  { href: "/contact", label: s.nav.contact },
];

// Builders dropdown — submenu of cohort pages.
const builders = {
  label: s.nav.builders,
  children: [{ href: "/cohort/1", label: s.nav.cohort1 }],
};
---

<header class="border-b border-white/5">
  <div
    class="mx-auto flex max-w-5xl items-center justify-between gap-3 px-5 py-4 sm:px-6"
  >
    <a
      href={localizedPath("/", locale)}
      class="flex items-center gap-2 text-lg font-black tracking-tight text-white no-underline hover:text-accent-500"
    >
      <img
        src={`${import.meta.env.BASE_URL}favicon.svg`}
        alt=""
        width="28"
        height="28"
        class="rounded-md"
      />
      <span>vibe<span class="text-accent-500">code</span>.tours</span>
    </a>

    <nav aria-label="Primary" class="hidden sm:block">
      <ul class="flex gap-x-4 text-sm">
        {
          nav.map((item) => (
            <li>
              <a
                href={localizedPath(item.href, locale)}
                class="inline-flex items-center px-1 py-2 text-gray-400 no-underline hover:text-white"
              >
                {item.label}
              </a>
            </li>
          ))
        }
        <li class="group relative">
          <button
            type="button"
            class="inline-flex items-center gap-1 px-1 py-2 text-gray-400 hover:text-white"
            aria-haspopup="true"
          >
            {builders.label}
            <svg class="h-3 w-3 opacity-60" viewBox="0 0 12 12" fill="none">
              <path
                d="M3 4.5 6 7.5 9 4.5"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </button>
          <div
            class="invisible absolute right-0 top-full z-20 mt-1 min-w-[10rem] rounded-lg border border-white/10 bg-surface-elevated p-1 opacity-0 shadow-xl transition-all duration-150 group-focus-within:visible group-focus-within:opacity-100 group-hover:visible group-hover:opacity-100"
          >
            {
              builders.children.map((c) => (
                <a
                  href={localizedPath(c.href, locale)}
                  class="block rounded-md px-3 py-2 text-sm text-gray-400 no-underline hover:bg-white/5 hover:text-white"
                >
                  {c.label}
                </a>
              ))
            }
          </div>
        </li>
      </ul>
    </nav>

    <div class="flex items-center gap-3">
      <a
        href={altHref}
        class="hidden items-center rounded-md border border-white/10 px-3 py-1.5 text-sm font-semibold text-gray-400 no-underline hover:border-accent-500/30 hover:text-white sm:inline-flex"
        lang={locale === "en" ? "my" : "en"}
      >
        {altLabel}
      </a>
      <a
        href={localizedPath("/apply", locale)}
        class="inline-flex items-center rounded-lg bg-accent-500 px-4 py-1.5 text-sm font-bold text-black no-underline hover:bg-accent-600"
      >
        {s.nav.apply} →
      </a>
      <button
        id="menu-toggle"
        type="button"
        class="inline-flex items-center justify-center rounded-md border border-white/10 p-2 text-gray-400 hover:border-accent-500/30 hover:text-white sm:hidden"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Toggle menu"
      >
        <svg
          class="h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="2"
          stroke="currentColor"
        >
          <path
            id="icon-open"
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
          <path
            id="icon-close"
            class="hidden"
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden border-t border-white/5 sm:hidden">
    <div class="mx-auto max-w-5xl px-5 py-4 sm:px-6">
      <ul class="flex flex-col gap-1">
        {
          nav.map((item) => (
            <li>
              <a
                href={localizedPath(item.href, locale)}
                class="block rounded-lg px-3 py-2.5 text-sm text-gray-400 no-underline hover:bg-white/5 hover:text-white"
              >
                {item.label}
              </a>
            </li>
          ))
        }
        <li>
          <p
            class="px-3 pb-1 pt-2 text-xs font-semibold uppercase tracking-wide text-gray-600"
          >
            {builders.label}
          </p>
          {
            builders.children.map((c) => (
              <a
                href={localizedPath(c.href, locale)}
                class="block rounded-lg px-3 py-2.5 text-sm text-gray-400 no-underline hover:bg-white/5 hover:text-white"
              >
                {c.label}
              </a>
            ))
          }
        </li>
      </ul>
      <div class="mt-3 border-t border-white/5 pt-3">
        <a
          href={altHref}
          class="block rounded-lg px-3 py-2.5 text-sm font-semibold text-gray-400 no-underline hover:bg-white/5 hover:text-white"
          lang={locale === "en" ? "my" : "en"}
        >
          {altLabel}
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const iconOpen = document.getElementById("icon-open");
  const iconClose = document.getElementById("icon-close");
  toggle?.addEventListener("click", () => {
    const open = menu?.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", String(open));
    iconOpen?.classList.toggle("hidden", open);
    iconClose?.classList.toggle("hidden", !open);
  });
</script>
