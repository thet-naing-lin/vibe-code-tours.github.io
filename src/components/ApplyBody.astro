---
import { t, getLocale, type Locale } from '../i18n/utils';

const locale: Locale = getLocale(Astro.url.pathname);
const s = t(locale).apply;
---

<article class="container-prose py-12">
  <div class="inline-flex items-center gap-2 rounded-full border border-accent-500/30 bg-accent-500/10 px-4 py-1.5 text-sm font-semibold text-accent-500">
    <span class="h-1.5 w-1.5 rounded-full bg-accent-500 animate-pulse"></span>
    Cohort 2 — Open
  </div>
  <h1 class="mt-4 text-3xl sm:text-4xl">{s.heading}</h1>
  <p class="mt-3 text-lg font-bold text-accent-500">{s.openBody}</p>
  <p class="mt-3 text-gray-500">{s.cohort1Note}</p>

  <div class="mt-8">
    <a
      href={s.formUrl}
      target="_blank"
      rel="noopener"
      class="btn btn-primary text-lg"
    >
      {s.ctaApply}
    </a>
  </div>

  <h2 class="mt-12 text-2xl">{s.lookHeading}</h2>
  <p class="mt-2 text-sm text-gray-600">{s.lookIntro}</p>
  <ul class="mt-3 list-disc space-y-1 pl-5 text-gray-400">
    {s.lookList.map((item) => <li>{item}</li>)}
  </ul>
</article>
